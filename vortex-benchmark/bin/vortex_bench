#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/../.." && pwd)"
export PYTHONPATH="$ROOT/vortex-benchmark/python${PYTHONPATH:+:$PYTHONPATH}"

if [[ -x "$ROOT/.venv/bin/python" ]]; then
	PYTHON_BIN="$ROOT/.venv/bin/python"
elif [[ -x "$ROOT/../.venv/bin/python" ]]; then
	PYTHON_BIN="$ROOT/../.venv/bin/python"
else
	PYTHON_BIN="python3"
fi

exec "$PYTHON_BIN" -m vortex_benchmark "$@"